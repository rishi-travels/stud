
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    match /vehicles/{vehicleId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == vehicleId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    match /news_articles/{articleId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == articleId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    match /promotions/{promoId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == promoId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    match /team_members/{memberId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == memberId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    match /branch_locations/{branchId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == branchId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    match /job_openings/{jobId} {
      allow get, list: if true;
      allow create: if isAdmin() && request.resource.data.id == jobId;
      allow update: if isExistingAdmin() && request.resource.data.id == resource.data.id;
      allow delete: if isExistingAdmin();
    }

    // Leads collections - Allow delete if signed in (Admin Dashboard uses anonymous auth)
    match /contact_inquiries/{inquiryId} {
      allow create: if request.resource.data.id == inquiryId;
      allow get, list: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /test_ride_bookings/{bookingId} {
      allow create: if request.resource.data.id == bookingId;
      allow get, list: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /job_applications/{applicationId} {
      allow create: if request.resource.data.id == applicationId;
      allow get, list: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /roles_admin/{adminId} {
      allow get: if (isSignedIn() && request.auth.uid == adminId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }
  }
}
